{
  "name": "video-player-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"npm run dev:dashboard\" \"node server/worker.js\" \"node server/migration-worker.js\"",
    "dev:dashboard": "cd dashboard && npm run dev",
    "build": "cd dashboard && npm run build",
    "worker": "node server/worker.js",
    "migration-worker": "node server/migration-worker.js",
    "db:migrate": "node server/db/migrate.js",
    "db:seed": "node server/db/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
